package com.example.raithavarta.ui

import androidx.compose.foundation.layout.*
import androidx.compose.foundation.lazy.LazyColumn
import androidx.compose.foundation.lazy.items
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Modifier
import androidx.compose.ui.unit.dp
import com.example.raithavarta.data.Tip

@Composable
fun HomeScreen() {

    val tips = listOf(
        Tip(
            "Tomato Advisory",
            "Spray neem oil this week to prevent leaf curl disease."
        ),
        Tip(
            "Rain Alert",
            "Avoid fertilizer today due to expected rainfall."
        ),
        Tip(
            "Soil Health",
            "Add organic compost for better moisture retention."
        )
    )

    Column(modifier = Modifier.fillMaxSize()) {

        Text(
            text = "Daily Tips",
            style = MaterialTheme.typography.headlineMedium,
            modifier = Modifier.padding(16.dp)
        )

        LazyColumn {
            items(tips) { tip ->
                Card(
                    modifier = Modifier
                        .fillMaxWidth()
                        .padding(10.dp)
                ) {
                    Column(modifier = Modifier.padding(16.dp)) {
                        Text(tip.title)
                        Spacer(modifier = Modifier.height(8.dp))
                        Text(tip.description)
                    }
                }
            }
        }
    }
}
